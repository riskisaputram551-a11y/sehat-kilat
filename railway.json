{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "composer install --ignore-platform-req=ext-gd && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "php artisan serve --host=0.0.0.0 --port=${PORT}",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "healthcheckTimeout": 100
  }
}